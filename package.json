{
  "name": "hcsa-interactive",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "HCSA Interactive — scroll-driven WebGL teardown of the Human-Centric Space Architecture habitat.",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "sync:geometry": "tsx scripts/sync-geometry.ts",
    "sync:types": "tsx scripts/generate-types.ts",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/a11y",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.0",
    "@fontsource/space-mono": "^5.2.0",
    "@mdx-js/react": "^3.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "howler": "^2.2.4",
    "lenis": "^1.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@gltf-transform/core": "^4.3.0",
    "@mdx-js/rollup": "^3.1.0",
    "@playwright/test": "^1.47.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/howler": "^2.2.12",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
